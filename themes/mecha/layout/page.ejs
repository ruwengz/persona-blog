<!-- Main Content -->
<main class="main-content">
  <% if (page.is_home) { %>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title"><%= config.title %></h1>
      <p class="hero-subtitle"><%= theme.subtitle %></p>
      <p class="hero-tagline"><%= config.description %></p>
      <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
        <a href="<%= theme.root %>daily/" class="btn">开始探索</a>
        <a href="<%= theme.root %>about/" class="btn btn-secondary">了解更多</a>
      </div>
    </div>
  </section>

  <!-- Posts Section -->
  <% var allPosts = site.posts.sort('date', -1); %>
  <% if (allPosts.length) { %>
  <section class="container">
    <h2 style="font-family: var(--font-title); color: var(--accent); text-align: center; margin: 40px 0 20px; letter-spacing: 2px;">
      &lt;最新文章/&gt;
    </h2>
    
    <div class="posts-grid">
      <% allPosts.each(function(post) { %>
      <article class="post-card">
        <h3 class="post-card-title">
          <a href="<%- url_for(post.path) %>"><%= post.title %></a>
        </h3>
        <div class="post-card-meta">
          <span class="category"><%= post.category || '日常' %></span>
          <span><%= date(post.date, 'YYYY-MM-DD') %></span>
        </div>
        <% var raw = post.content || ''; %>
        <% var plain = raw.replace(/<[^>]+>/g, '').substring(0, 100); %>
        <p class="post-card-excerpt"><%= plain %><% if (plain.length >= 100) { %>...<% } %></p>
        <div class="post-card-footer">
          <a href="<%- url_for(post.path) %>" class="read-more">阅读更多 →</a>
        </div>
      </article>
      <% }); %>
    </div>
  </section>
  <% } %>

  <% } else if (page.layout === 'page' && page.title === '留言板') { %>
  <!-- 留言板页面 -->
  <section class="message-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title"><%= page.title %></h1>
        <p class="page-subtitle"><%= page.content %></p>
      </header>

      <!-- 页面介绍 -->
      <div class="page-intro">
        <%- page.content %>
      </div>

      <!-- 留言表单 -->
      <div class="message-form-wrapper">
        <form name="message-form" action="https://formspree.io/f/你的表单ID" method="POST" class="message-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="name">
                <svg class="form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
                你的代号
              </label>
              <input type="text" id="name" name="name" required placeholder="输入你的昵称">
            </div>
            
            <div class="form-group">
              <label for="email">
                <svg class="form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                联系方式
              </label>
              <input type="email" id="email" name="email" placeholder="邮箱（选填）">
            </div>
          </div>
          
          <div class="form-group full">
            <label for="message">
              <svg class="form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              留言内容
            </label>
            <textarea id="message" name="message" required placeholder="说点什么吧..."></textarea>
          </div>
          
          <button type="submit" class="btn submit-btn">
            <span class="btn-text">发送信号</span>
            <span class="btn-icon">→</span>
          </button>
        </form>
      </div>

      <!-- 留言列表 -->
      <div class="message-board">
        <h2 class="message-board-title">
          <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          通讯记录
        </h2>
        <div class="message-list" id="messageList">
          <div class="message-item system">
            <div class="message-badge">SYSTEM</div>
            <div class="message-author">机甲Admin</div>
            <div class="message-time">2024-01-15 00:00</div>
            <div class="message-content">欢迎来到机甲世界！这里是留言板，留下你的足迹吧。</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // 表单提交处理
    document.querySelector('form[name="message-form"]')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const form = this;
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.querySelector('.btn-text').textContent;
      
      btn.classList.add('loading');
      btn.querySelector('.btn-text').textContent = '传输中...';
      btn.disabled = true;
      
      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        });
        
        if (response.ok) {
          btn.querySelector('.btn-text').textContent = '✓ 发送成功';
          btn.classList.remove('loading');
          btn.classList.add('success');
          form.reset();
          
          // 添加新留言到列表
          const name = form.querySelector('#name').value || '匿名访客';
          const message = form.querySelector('#message').value;
          const now = new Date();
          const time = now.toISOString().split('T')[0] + ' ' + now.toTimeString().slice(0, 5);
          
          const newMessage = document.createElement('div');
          newMessage.className = 'message-item new';
          newMessage.innerHTML = `
            <div class="message-badge">NEW</div>
            <div class="message-author">${escapeHtml(name)}</div>
            <div class="message-time">${time}</div>
            <div class="message-content">${escapeHtml(message)}</div>
          `;
          document.getElementById('messageList').prepend(newMessage);
          
          setTimeout(() => {
            btn.querySelector('.btn-text').textContent = originalText;
            btn.classList.remove('success');
            btn.disabled = false;
          }, 3000);
        } else {
          throw new Error('发送失败');
        }
      } catch (error) {
        btn.querySelector('.btn-text').textContent = '✗ 发送失败';
        btn.classList.remove('loading');
        setTimeout(() => {
          btn.querySelector('.btn-text').textContent = originalText;
          btn.disabled = false;
        }, 3000);
      }
    });
    
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>

  <% } else { %>
  <!-- 普通页面 -->
  <section class="container">
    <div class="page-content">
      <% if (page.title) { %>
      <header class="page-header">
        <h1 class="page-title"><%= page.title %></h1>
      </header>
      <% } %>
      
      <div class="page-body">
        <%- page.content %>
      </div>
    </div>
  </section>
  <% } %>
</main>
