<!-- Daily Page - 日常页面 -->
<section class="page-header">
  <div class="container">
    <h1 class="page-title">日常</h1>
    <p class="page-subtitle">记录生活的点滴，分享技术心得</p>
  </div>
</section>

<section class="container">
  <div class="posts-grid">
    <% site.posts.each(function(post) { %>
    <% if (post.categories && post.categories.data[0] && post.categories.data[0].name === 'daily') { %>
    <article class="post-card">
      <h3 class="post-card-title">
        <a href="<%- url_for(post.path) %>"><%= post.title %></a>
      </h3>
      <div class="post-card-meta">
        <span class="category">日常</span>
        <span><%= date(post.date, 'YYYY-MM-DD') %></span>
      </div>
      <p class="post-card-excerpt"><%= excerpt(post.content, {length: 100}) %></p>
      <div class="post-card-footer">
        <a href="<%- url_for(post.path) %>" class="read-more">阅读更多 →</a>
      </div>
    </article>
    <% } %>
    <% }); %>
  </div>
</section>
